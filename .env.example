# Rithmic AMP credentials
RITHMIC_AMP_USER=your_amp_email@amp.com
RITHMIC_AMP_PASSWORD=your_password
RITHMIC_AMP_SYSTEM=Rithmic 01
RITHMIC_APP_NAME=nepa:OentexNQBot
RITHMIC_APP_VERSION=1.0
RITHMIC_SYMBOL=NQ
RITHMIC_EXCHANGE=CME

# Cloudflare R2
# Get from: dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=your_32_char_account_id
R2_ACCESS_KEY=your_r2_key_id
R2_SECRET_KEY=your_r2_secret
R2_BUCKET=nq-ticks
R2_PREFIX=rithmic_engine/
