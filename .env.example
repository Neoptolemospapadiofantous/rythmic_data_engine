# ── Rithmic AMP credentials (TICKER_PLANT — market data) ───────────
RITHMIC_AMP_USER=your_amp_email@amp.com
RITHMIC_AMP_PASSWORD=your_password
RITHMIC_AMP_SYSTEM=Rithmic 01
RITHMIC_AMP_URL=wss://rituz00100.rithmic.com:443
RITHMIC_APP_NAME=nepa:OentexNQBot
RITHMIC_APP_VERSION=1.0
RITHMIC_SYMBOL=NQ
RITHMIC_EXCHANGE=CME

# ── Rithmic Legends credentials (ORDER_PLANT — prop firm execution) ─
RITHMIC_LEGENDS_USER=your_legends_email@example.com
RITHMIC_LEGENDS_PASSWORD=your_password
RITHMIC_LEGENDS_SYSTEM=LegendsTrading
RITHMIC_LEGENDS_URL=wss://rituz00100.rithmic.com:443

# ── PostgreSQL ──────────────────────────────────────────────────────
# On Oracle VM (used by nq_executor to write trade data):
#   PG_HOST=127.0.0.1   ← PostgreSQL runs locally on the VM
#
# On developer workstation (used by /bot UI to read live data):
#   Add PG_HOST=<oracle_vm_public_ip> to /bot/.env instead —
#   that file takes priority over this one for UI connections.
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=rithmic
PG_USER=rithmic_user
PG_PASSWORD=your_strong_password_here
