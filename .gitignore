# Credentials — never commit
.env

# Data directory (DB files, logs, live state, PID)
data/

# C++ build artifacts
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
*.o
*.a
*.so
compile_commands.json

# Generated protobuf files
proto/*.pb.cc
proto/*.pb.h

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Claude Code workspace
.claude/

# ML models (generated by training pipeline — not source code)
models/*.pkl
models/*.joblib
# Keep checksums file (committed intentionally)
!config/model_checksums.json
*.png
